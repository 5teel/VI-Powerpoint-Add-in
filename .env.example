# Cube AI Configuration
# Get API key from Cube Cloud: Admin > Agents > API Key
CUBEAI_API_KEY=your-api-key-here
CUBEAI_BASE_URL=https://ai.gcp-us-central1.cubecloud.dev/api/v1/public/summitinsights/agents/11/chat/stream-chat-state
CUBEAI_EXTERNAL_ID=user@summit.com
CUBEAI_TIMEOUT_MS=180000

# Anthropic Composer Configuration (Phase 5)
# Get API key from Anthropic Console. Note: key is surfaced in the client bundle
# (D-04 accepted trade-off for internal sideload). Never ship to AppSource without
# a server-side proxy.
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Cube REST Data API Configuration (Phase 5)
# Deployment-specific — must match the deployment the Cube AI agent is linked to (D-24)
CUBE_DATA_BASE_URL=https://<deployment>.cubecloud.dev
CUBE_DATA_JWT=your-jwt-here
